rules_version = '2';

// Cloud Storage security rules — mirror the Firestore model: users only touch
// their own folder. Caps individual uploads at 20 MB to match the app's
// MAX_UPLOAD_BYTES constant in lib/uploadLimits.ts.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid
                         && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
