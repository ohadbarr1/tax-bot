rules_version = '2';

// Cloud Storage security rules — mirror the Firestore model: users only touch
// their own folder. Writes are capped at 20 MB (matches MAX_UPLOAD_BYTES in
// lib/uploadLimits.ts). Read is split from write because `request.resource`
// is null on reads, so a combined rule with `request.resource.size < …`
// evaluates false on GET/getDownloadURL and breaks preview links.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null
                  && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
