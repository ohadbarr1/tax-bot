rules_version = '2';

// Firestore security rules — every read/write must be authenticated (including
// anonymous sign-in) and scoped to the caller's own uid. Admins (allow-listed
// in `admins/{uid}`) may read any user's documents via the portal; they never
// write user data directly — destructive actions go through the API routes
// which use the Admin SDK and bypass rules entirely.
service cloud.firestore {
  match /databases/{database}/documents {

    // True when the caller is in the admin allow-list. The `admins/{uid}`
    // collection itself is locked down at rest — only the Admin SDK (via
    // Firebase Console or a server route) can write it, so this exists()
    // check is trustworthy.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin allow-list — NEVER readable or writable from a client. Admins
    // are bootstrapped via the Firebase Console (see DEPLOY.md).
    match /admins/{uid} {
      allow read, write: if false;
    }

    match /users/{uid}/{document=**} {
      allow read:  if (request.auth != null && request.auth.uid == uid) || isAdmin();
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
