rules_version = '2';

// Firestore security rules — every read/write must be authenticated (including
// anonymous sign-in) and scoped to the caller's own uid. Admins (allow-listed
// in `admins/{uid}`) may read any user's documents via the portal; they never
// write user data directly — destructive actions go through the API routes
// which use the Admin SDK and bypass rules entirely.
service cloud.firestore {
  match /databases/{database}/documents {

    // True when the caller is in the admin allow-list. The `admins/{uid}`
    // collection itself is locked down at rest — only the Admin SDK (via
    // Firebase Console or a server route) can write it, so this exists()
    // check is trustworthy.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin allow-list — NEVER readable or writable from a client. Admins
    // are bootstrapped via the Firebase Console (see DEPLOY.md).
    match /admins/{uid} {
      allow read, write: if false;
    }

    match /users/{uid}/{document=**} {
      allow read:  if (request.auth != null && request.auth.uid == uid) || isAdmin();
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Phase 2 §2.B — tamper-evident audit log. Admin SDK writes (server only)
    // bypass these rules; clients have NO read or write access. Admins read
    // through the portal, which routes via the Admin SDK as well — direct
    // client read is intentionally blocked to keep the chain auditable
    // (any leak would otherwise let a snooping admin learn the chain head).
    match /audit_events/{eventId} {
      allow read, write: if false;
    }
  }
}
