rules_version = '2';

// Firestore security rules — every read/write must be authenticated (including
// anonymous sign-in) and scoped to the caller's own uid. Deny all else.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
