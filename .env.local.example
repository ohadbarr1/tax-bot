# ─── Anthropic (AI advisor) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Firebase client (browser) ────────────────────────────────────────────────
# Found at Firebase Console → Project Settings → General → Your apps → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase App Check (security-F1.1.4 / F1.3.2) ────────────────────────────
# reCAPTCHA v3 site key for the App Check provider. Without this, App Check is
# DISABLED in dev (the client logs a single warning on boot) — production must
# set it. Get a key at https://www.google.com/recaptcha/admin/create then
# register it in Firebase Console → App Check → reCAPTCHA v3. See DEPLOY.md.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ─── Firebase admin (server) ─────────────────────────────────────────────────
# On Firebase App Hosting these come from Application Default Credentials
# automatically — leave blank in the `apphosting.yaml` env block.
# For local dev, either:
#   (a) run `gcloud auth application-default login`, or
#   (b) download a service-account JSON and set:
#       GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# ─── Upstash Redis (rate limiting, F-2 / F1.2.1) ─────────────────────────────
# Provision a database at https://console.upstash.com/redis and copy the
# REST endpoint + token. Without these, `withRateLimit` no-ops and prints a
# warning (so dev and CI keep working). PRODUCTION must set both.
# UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# ─── Sentry (observability, performance §1.6) ───────────────────────────────
# Provision a project at https://sentry.io and copy the DSN. Both vars hold
# the same DSN value; the NEXT_PUBLIC_ one is exposed to the browser bundle.
# SENTRY_AUTH_TOKEN is only needed at build time for source-map upload —
# without it the build still succeeds but client stack traces won't be
# symbolicated. Without SENTRY_DSN, `lib/sentry.{server,client}.ts` no-op
# (so dev and CI keep working without provisioning Sentry).
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_AUTH_TOKEN=
# Optional: `release` tag for grouping events by deploy. CI sets this from
# the git SHA. Leave unset locally.
# GIT_SHA=
# NEXT_PUBLIC_GIT_SHA=
